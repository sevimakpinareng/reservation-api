# Copy this file to `.env` (which is gitignored) and fill in real values.
# These values are consumed by docker-compose.yml (PostgreSQL + API services).

# --- PostgreSQL ---
POSTGRES_DB=reservationdb
POSTGRES_USER=reservation
POSTGRES_PASSWORD=change-me-to-a-strong-local-password
# Host port the database is published on (container always listens on 5432).
POSTGRES_PORT=5432

# --- API ---
# Host port the API is published on.
API_PORT=8080
# JWT signing key — MUST be long and random (>= 32 chars). Never commit a real value.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters
JWT_ISSUER=ReservationSystem
JWT_AUDIENCE=ReservationSystem
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
